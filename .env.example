# Copy to .env in this folder (repo root). Used by `netlify dev` for Mux upload in studio.
# Never commit .env — it is in .gitignore.

MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Required before deploying studio to production. Long random string (32+ chars).
# Same value unlocks studio in the browser and authorizes Mux API functions.
STUDIO_API_SECRET=
