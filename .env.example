# Copy to .env in this folder (repo root). Used by `netlify dev` for Mux upload in studio.
# Never commit .env — it is in .gitignore.

MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Required before deploying studio to production. Long random string (32+ chars).
# Same value unlocks studio in the browser and authorizes Mux API functions.
STUDIO_API_SECRET=

# Tier 1 — mirror from Netlify dashboard (see STUDIO-MASTER-PLAN.md)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=anthropic
AI_MODEL=claude-haiku-4-5

# Tier 2 — R2 vault + LabelGrid (see studio/TIER-2-SETUP.md)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=burnfolder-masters
LABELGRID_API_KEY=
DISTRO_PROVIDER=labelgrid
# LABELGRID_SANDBOX=true
# LABELGRID_LABEL_ID=
# LABELGRID_ARTIST_ID=
# LABELGRID_WRITER_ID=
# LABELGRID_PRIMARY_GENRE_ID=
